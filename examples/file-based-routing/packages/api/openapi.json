          }
        },
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": false
      },
      "ShopRecipesListOutput": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "number"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "name"
          ],
          "additionalProperties": false
        }
      },
      "ShopCateringBookInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "date": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "date"
        ]
      },
      "ShopCateringBookOutput": {
        "type": "object",
        "properties": {
          "confirmed": {
            "type": "boolean"
          },
          "for": {
            "type": "string"
          },
          "on": {
            "type": "string"
          }
        },
        "required": [
          "confirmed",
          "for",
          "on"
        ],
        "additionalProperties": false
      },
      "ShopHomepageOutput": {
        "type": "object",
        "properties": {
          "tagline": {
            "type": "string"
          }
        },
        "required": [
          "tagline"
        ],
        "additionalProperties": false
      },
      "ShopStatsOutput": {
        "type": "object",
        "properties": {
          "visitors": {
            "type": "number"
          }
        },
        "required": [
          "visitors"
        ],
        "additionalProperties": false
